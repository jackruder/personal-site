---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/layout/BaseLayout.astro';

const recentPosts = (await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true)))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });
const getPostUrl = (post) => `/blog/${post.id.replace(/\.mdx$/, '')}/`;
---

<BaseLayout title="Jack Ruder" description="Landing page and technical blog for Jack Ruder, working on probabilistic machine learning.">
  <section class="hero">
    <p class="muted">Student · Researcher</p>
    <h1>Jack Ruder</h1>
    <p>
      I work on probabilistic machine learning and use this site for a small landing page plus other fun stuff.
    </p>
    <nav aria-label="Profile links">
      <ul class="link-list">
        <li><a href="/blog">Blog</a></li>
        <li><a href="/cv">CV</a></li>
        <li><a href="mailto:contact@jackruder.xyz">Email</a></li>
        <li><a href="https://github.com/jackruder">GitHub</a></li>
        <li><a href="https://scholar.google.com/citations?user=HvM1f3IAAAAJ">Scholar</a></li>
        <li><a href="https://linkedin.com/in/jack-ruder-11076815a">LinkedIn</a></li>
      </ul>
    </nav>
  </section>

  <section class="section-stack" aria-labelledby="recent-posts">
    <div class="card">
      <h2 id="recent-posts">Recent posts</h2>
      {recentPosts.length === 0 ? (
        <p>No posts yet.</p>
      ) : (
        <ul class="post-list">
          {recentPosts.map((post) => (
            <li>
              <h3><a href={getPostUrl(post)}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              <p class="muted">{dateFormatter.format(post.data.pubDate)}</p>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>
